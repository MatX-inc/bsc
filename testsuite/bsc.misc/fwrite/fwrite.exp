
# These tests fire a file-writing rule and a $finish rule in the same
# cycle.  BSC emits the $finish before the same-cycle $fwrite in the
# generated task block; event-driven simulators (and Bluesim) stop at the
# $finish statement, but Verilator's documented $finish semantics finish
# the current eval first, so the final cycle's write still lands in the
# .dat file (the harness already truncates *stdout* at $finish for
# verilator, see verilog.tcl).  The .verilator goldens are therefore the
# base goldens plus that one extra final-cycle write; every shared line
# is byte-identical.  check_verilog_output (veribug "") is a drop-in for
# compare_file that picks up the sim-keyed golden.

if { $vtest } {
    test_veri_only_bsv FOpen
    check_verilog_output FOpen.dat.out FOpen.dat.out.expected ""
}
if { $ctest } {
    test_c_only_bsv FOpen
    compare_file FOpen.dat.out 
}

if { $vtest } {
    test_veri_only_bsv FOpen2
    compare_file FOpen2.dat.out 
}

if { $ctest } {
    test_c_only_bsv FOpen2
    compare_file FOpen2.dat.out 
}

## 
compile_fail_error FOpen3.bsv T0020


## Some multi channel tests

if { $vtest } {
    # sysFOpen_MCD.out.expected.verilator also differs in the displayed
    # $fopen MCD handle value: the multichannel-descriptor bit allocation
    # is implementation-defined (iverilog hands out bit 1 = 00000002,
    # verilator bit 30 = 40000000); all written data is identical.
    test_veri_only_bsv FOpen_MCD
    check_verilog_output FOpen_MCD.dat.out FOpen_MCD.dat.out.expected ""
}
if { $ctest } {
    test_c_only_bsv FOpen_MCD
    compare_file FOpen_MCD.dat.out 
}

if { $vtest } {
    test_veri_only_bsv FOpen_MCD2
    compare_file FOpen_MCD2.dat.out 
}
if { $ctest } {
    test_c_only_bsv FOpen_MCD2
    compare_file FOpen_MCD2.dat.out 
}

