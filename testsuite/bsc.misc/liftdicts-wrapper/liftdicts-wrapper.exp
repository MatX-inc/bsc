# Dictionary lifting in the module-wrapper compilation path, and the
# typechecker's ground-dictionary pool (LiftDicts / TypeCheck/TCMisc).
#
# WrapperDicts is a synthesized module whose interface methods repeat
# a family of nested struct types; its generated wrapper needs a
# dictionary (Bits, SplitPorts, WrapPorts, WrapMethod, ...) per
# method-argument/result type per use site, and the typechecker mints
# each one fresh.  The wrapper compilation path (compileCDefToIDef)
# runs dictionary lifting before its ISyntax conversion, so the
# converted interface definition references each distinct dictionary
# once instead of re-expanding its construction at every use; the
# lifted definitions travel through the .bo, and LiftWrapTb -- a
# separately compiled importer -- must resolve them when it elaborates
# the module from the .bo.
#
# The second variant enables -hack-ground-ctype (a measurement toggle
# for benchmarking): the typechecker pools fully-ground, fully-
# coherent dictionary derivations into top-level _lifted_dict defs at
# solve time, and the LiftDicts pass adopts those defs -- same naming
# scheme and DefProps -- and lifts whatever remains itself.  The
# combined case must produce no name collisions and exactly the same
# design: the compile fails internal consistency checks on any
# mismatch, and the simulation output pins the behavior.

# dictionary lifting alone (the default flags)
compile_object_pass WrapperDicts.bs {} {-no-warn-action-shadowing}
test_c_only_bs_modules_options LiftWrapTb {} {-no-warn-action-shadowing} sysLiftWrapTb.out.expected

# typechecker ground-dictionary pooling on top of the pass
compile_object_pass WrapperDicts.bs {} {-no-warn-action-shadowing -hack-ground-ctype}
test_c_only_bs_modules_options LiftWrapTb {} {-no-warn-action-shadowing -hack-ground-ctype} sysLiftWrapTb.out.expected

# the all-miss face of the pool: every definition in DistinctGrounds
# demands dictionaries at a distinct large ground type, so top-level
# probes never hit and each consultation pays the ground-CType
# interning walk; compiling cleanly in both modes is the assertion
compile_pass DistinctGrounds.bs
compile_pass DistinctGrounds.bs {-hack-ground-ctype}
